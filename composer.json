{
    "name": "jardisadapter/http",
    "description": "PSR-18 HTTP client with cURL transport, Bearer and Basic auth, minimal footprint",
    "type": "library",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Headgent Development",
            "email": "jardisDev@headgent.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "psr/http-client": "^1.0",
        "psr/http-message": "^2.0",
        "ext-curl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^2.0.4",
        "squizlabs/php_codesniffer": "^3.11.2",
        "nyholm/psr7": "^1.8"
    },
    "suggest": {
        "nyholm/psr7": "Required for PSR-7 message objects (Request, Response, Uri, Stream)"
    },
    "autoload": {
        "psr-4": {
            "JardisAdapter\\Http\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JardisAdapter\\Http\\Tests\\": "tests/"
        }
    },
    "homepage": "https://github.com/jardisAdapter/http",
    "support": {
        "issues": "https://github.com/jardisAdapter/http/issues",
        "email": "jardisDev@headgent.com"
    },
    "keywords": [
        "http",
        "psr-18",
        "psr-7",
        "curl",
        "client",
        "domain driven design",
        "jardis",
        "Headgent"
    ]
}
